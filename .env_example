# agentY MCP server — secrets. Copy to `.env` and fill in.
#
# The MCP host (Claude Desktop) supplies the model, so NO Anthropic/LLM key is
# needed here. These are only for ComfyUI access and HuggingFace downloads.

# HuggingFace token — required to download gated models.
# Create one at https://huggingface.co/ (account → Access Tokens).
HF_TOKEN=hf_...

# ComfyUI API key — only needed if your ComfyUI requires auth or you use the
# ComfyUI API nodes (https://platform.comfy.org/profile/api-keys). Leave blank
# for an unauthenticated local ComfyUI.
COMFYUI_API_KEY=

# Optional: disable long-term memory tools entirely.
# MEMORY_ENABLED=false
