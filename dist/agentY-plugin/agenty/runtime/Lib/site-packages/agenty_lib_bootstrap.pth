# agentY: register the bundled plugin lib as a real site directory so that
# .pth files inside it (notably pywin32.pth) are processed at interpreter
# startup. Without this, pywin32's bootstrap never runs and `import pywintypes`
# fails, which prevents the bundled `mcp` library (and the agentY server) from
# importing on Windows. Path is derived from sys.prefix so it stays valid
# wherever the plugin is installed (runtime/ and lib/ are siblings).
import os, site; site.addsitedir(os.path.normpath(os.path.join(os.path.dirname(os.__file__), os.pardir, os.pardir, 'lib')))
